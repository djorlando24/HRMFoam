FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    location    "0";
    object      nut;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 2 -1 0 0 0 0];

internalField   uniform 1.2e-4; // sqrt(1.5)*(U*turbIntensity*turbLengthScale)

boundaryField
{
    inlet
    {
        type            calculated;
        value           $internalField;
    }
    
    outlet
    {
        type            calculated;
        value           $internalField;
    }
       
    wall
    {
        type            nutkWallFunction;
        Cmu             0.09;
        kappa           0.41;
        E               9.8;
        value           $internalField;

    }
    
    frontAndBackPlanes_pos           
    {
        type            wedge;
    }

    frontAndBackPlanes_neg           
    {
        type            wedge;
    }
    
    axis            
    {
        type            empty;
    }

}


