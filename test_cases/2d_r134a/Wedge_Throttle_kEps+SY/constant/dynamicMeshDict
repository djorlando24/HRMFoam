FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      thermophysicalProperties;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

//dynamicFvMesh dynamicMotionSolverFvMesh;
//dynamicFvMesh  subsetMotionSolverFvMesh;

twoDMotion      yes;

dynamicFvMesh  staticFvMesh;

motionSolverLibs ("libfvMotionSolvers.so");

//solver laplacian;
//solver velocityComponentLaplacian x;

solver   laplaceFaceDecomposition;

diffusivity     quadratic;

frozenDiffusion off;

distancePatches
(
    movingWall
    movingFarfield
    movingSlipWall
    wall
);


