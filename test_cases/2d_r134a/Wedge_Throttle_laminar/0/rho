FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    object      rho;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [1 -3 0 0 0 0 0];

internalField   uniform 1000;

boundaryField
{

    inlet            
    {

        type    thermDensity;  
        inletValue      uniform 1000.0;
        value           uniform 1000.0;
    }
    
    outlet
    {
        type    thermDensity;
        inletValue     uniform 5;
        value          uniform 1000;
    }
    
    slipWall       
    {
        type            zeroGradient;
    }

    wall       
    {
        type            zeroGradient;
    }

    axis            
    {
        type            empty;
    }

    frontAndBackPlanes_pos           
    {
        type            wedge;
    }

    frontAndBackPlanes_neg           
    {
        type            wedge;
    }  
 
}

