FoamFile
{
    version     2.0;
    format      binary;
    class       volScalarField;
    location    "0";
    object      p;
}

dimensions      [1 -1 -2 0 0 0 0];

internalField   uniform 0; 

boundaryField
{
    inlet
    {
        type            totalPressure;
        rho             none;
        psi             none;
        gamma           1.55;
        p0              uniform 665000;
        value           uniform 665000;
    }
    outlet
    {
        type            transonicTotalPressure;
	U		U;
	phi		phiv;
	rho		rho;
	psi		none;
	gamma		1.55;
	p0		100000;
	value		uniform 100000;
    }
    walls
    {
        type            zeroGradient;
    }
    allBoundary
    {
        type		zeroGradient;
    }
}


