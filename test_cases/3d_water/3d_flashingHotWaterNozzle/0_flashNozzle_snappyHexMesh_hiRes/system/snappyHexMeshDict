FoamFile
{
    version     1.6;
    format      ascii;
    class       dictionary;
    object      snappyHexMeshDict;
}

castellatedMesh true;
snap            true;
addLayers       false;


geometry
{
    inlet.stl
    {
        type triSurfaceMesh;
        name inlet;
    }

    outlet.stl
    {
        type triSurfaceMesh;
        name outlet;
    }

    walls.stl
    {
        type triSurfaceMesh;
        name walls;
    }

    // Refinement Zones (custom)
    refineOutside 
    {
        type searchableCylinder;
        point1 (0 0 -0.25);
        point2 (0 0 -22.5);
        radius 15;
    }

    refineInside
    {
        type searchableCylinder;
        point1 (0 0 18.5);
        point2 (0 0 -17.5);
        radius 8;
    }

    refineInside2
    {
        type searchableCylinder;
        point1 (0 0 -2);
        point2 (0 0 -7.5);
        radius 3;
    }

    refineInside3
    {
        type searchableCylinder;
        point1 (0 0 -1.8);
        point2 (0 0 -3.2);
        radius 0.3;
    }


};


castellatedMeshControls
{
    maxLocalCells   100000000;
    maxGlobalCells  100000000;
    minRefinementCells 10;
    maxLoadUnbalance 0.10;
    nCellsBetweenLevels 5;
    features
    (
	{
		file "walls.eMesh";
		level 2;
	}

        {
                file "inlet.eMesh";
                level 1;
        }

        {
                file "outlet.eMesh";
                level 1;
        }

    );
    refinementSurfaces
    {
	inlet
        {
            level (0 0);
        }

	outlet
        {
            level (0 0);
        }

        walls
        {
            level (1 2);
            gapLevelIncrement 2;
	}
    }
    resolveFeatureAngle 30;

    refinementRegions
    {
	refineOutside
        {
	    mode inside;
	    levels ((1 1));
        }

	refineInside
        {
	    mode inside;
	    levels ((1 2));
        }

	refineInside2
        {
	    mode inside;
	    levels ((2 4));
        }

	refineInside3
        {
	    mode inside;
	    levels ((4 5));
        }
    }

    // Inside the STL volume
    // where mesh starts, usually set at origin for grid to be as symmetric as possible. 
    locationInMesh (0 0 -1e-6); 

    allowFreeStandingZoneFaces true;
}

snapControls
{
    nSmoothPatch 3;
    tolerance 4.0;
    nSolveIter 30;
    nRelaxIter 5;
    nFeatureSnapIter 10;
}

addLayersControls
{
    relativeSizes true;
    
    layers
    {
	
        "walls"
        {
            nSurfaceLayers 3;
        }
     
        "inlet"
        {
            nSurfaceLayers 5;
        }

        "outlet"
        {
            nSurfaceLayers 10;
        }
	
    }

    expansionRatio 1.2;
    finalLayerThickness 0.8;
    minThickness 0.1;
    nGrow 0;
    featureAngle 60;
    nRelaxIter 8;
    nSmoothSurfaceNormals 3;
    nSmoothNormals 10;
    nSmoothThickness 10;
    maxFaceThicknessRatio 0.5;
    maxThicknessToMedialRatio 0.3;
    minMedianAxisAngle 130;
    nBufferCellsNoExtrude 0;
    nLayerIter 30;
    minMedialAxisAngle 130;
}

meshQualityControls
{
    maxNonOrtho 65; //80;
    maxBoundarySkewness 20;
    maxInternalSkewness 4; //5;
    maxConcave 80;
    minVol 1e-13;
    minTetQuality 1e-30;
    minArea -1;
    minTwist 0.02;
    minDeterminant 0.001;
    minFaceWeight 0.02;
    minVolRatio 0.01;
    minTriangleTwist -1;
    nSmoothScale 4;
    errorReduction 0.75;
}


// 0 : only write final meshes
// 1 : write intermediate meshes
// 2 : write volScalarField with cellLevel for postprocessing
// 4 : write current intersections as .obj files
debug 0;

mergeTolerance 1e-6;
