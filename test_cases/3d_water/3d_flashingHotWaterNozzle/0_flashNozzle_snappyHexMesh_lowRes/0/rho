FoamFile
{
    version     2.0;
    format      binary;
    class       volScalarField;
    location    "0";
    object      rho;
}

dimensions      [1 -3 0 0 0 0 0];

internalField   uniform 0;
boundaryField
{
    inlet //inflow boundary
    {
        type            thermDensity;
        phi             phiv;
        value           uniform 1110.646766;
    }
    
    outlet //outflow boundary
    {
        type            thermDensity;
        phi             phiv;
        inletValue      uniform 16.20667194;
        value           uniform 16.20667194;
    }

    walls
    {
        type            zeroGradient;
    }

    allBoundary
    {
        type            zeroGradient;
    }
}


