FoamFile
{
    version     2.0;
    format      ascii;
    arch        "LSB;label=32;scalar=64";
    class       volScalarField;
    location    "0";
    object      rho;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [1 -3 0 0 0 0 0];

internalField   uniform 796.673;

boundaryField
{
    inlet
    {
        type            thermDensity;
        inletValue      uniform 796.673;
        value           uniform 796.673;
    }
    outlet
    {
        type            thermDensity;
        inletValue      uniform 1.95;
        value           uniform 797;
    }
    walls
    {
        type            zeroGradient;
    }
}


