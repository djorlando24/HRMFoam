FoamFile
{
    version     2.0;
    format      ascii;
    arch        "LSB;label=32;scalar=64";
    class       volScalarField;
    location    "0";
    object      p;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [1 -1 -2 0 0 0 0];

internalField   uniform 6000000;

boundaryField
{
    inlet
    {
        type            transonicTotalPressure;
        phi             phiv;
        p0              6000000;
        value           uniform 6000000;
    }
    outlet
    {
        type            timeVaryingTransonicTotalPressure;
        U               U;
        phi             phiv;
        file            "outP.dat";
        rho             rho;
        psi             none;
        gamma           1;
        p0              6000000;
        value           uniform 6000000;
    }
    walls
    {
        type            zeroGradient;
    }
}


