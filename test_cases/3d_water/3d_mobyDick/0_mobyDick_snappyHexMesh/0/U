FoamFile
{
    version     2.0;
    format      binary;
    class       volVectorField;
    location    "6e-08";
    object      U;
}

dimensions      [0 1 -1 0 0 0 0];

internalField   uniform (0 0 0);

boundaryField
{
    
    inlet //inflow boundary
    {
        type            zeroGradient; //pressureInletOutletVelocity;
        outletValue     uniform (0 0 0);
        value           uniform (0 0 0);
    }
    
    outlet //outflow boundary
    {
  	    type            zeroGradient; //pressureInletOutletVelocity;
        inletValue      uniform (0 0 0);
        value           uniform (0 0 0);
    }

    walls
    {
        type            fixedValue;
        value           uniform (0 0 0);
    }

    allBoundary
    {
        type            zeroGradient;
    }
}


