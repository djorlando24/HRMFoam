FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    object      rho;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [1 -3 0 0 0 0 0];

internalField   uniform 958.37;

boundaryField
{
    walls     
    {
        type            zeroGradient;
    }

    inlet            
    {

      type    thermDensity;  
        inletValue      uniform 958.37;
        value           uniform 958.37;
    }

    outlet
    {
        type    thermDensity;
        inletValue     uniform 2.565; // when vapour at backpressure 
        value          uniform 958.37;
    }
  
 
}

