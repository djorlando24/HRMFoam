FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    object      motionProperties;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

twoDMotion      yes;

dynamicFvMesh  staticFvMesh;

motionSolverLibs ("libfvMotionSolvers.so");

solver   laplaceFaceDecomposition;

diffusivity     quadratic;

frozenDiffusion off;

distancePatches
(
    movingWall
    movingFarfield
    movingSlipWall
    wall
);


